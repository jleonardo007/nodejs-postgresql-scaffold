{
  "name": "nodejs-postgresql-scaffold",
  "version": "0.4.0",
  "description": "Script to generate a complete backend folder structure",
  "type": "module",
  "main": "index.js",
  "bin": {
    "create-backend": "./bin/index.js"
  },
  "scripts": {
    "create": "node bin/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:check": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "npm run lint:check && npm run format:check",
    "prepare": "husky",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run"
  },
  "files": [
    "bin",
    "lib"
  ],
  "keywords": [
    "backend",
    "scaffold",
    "nodejs",
    "expressjs",
    "typeorm",
    "postgresql"
  ],
  "author": "Leonardo Bravo",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.2.1",
    "chalk": "^5.6.2"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint/js": "10.0.1",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.5.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.3",
    "vitest": "4.1.5"
  }
}
