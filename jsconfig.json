{
  "compilerOptions": {
    "module": "esnext",
    "target": "es2024",
    "moduleResolution": "bundler",
    "strict": true,
    "paths": {
      "#lib": ["./lib/index.js"],
      "#lib/*": ["./lib/*"]
    }
  },
  "include": ["bin/**/*", "lib/**/*", "tests/**/*"],
  "exclude": ["node_modules"]
}
